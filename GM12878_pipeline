# Function to create an annotated dataframe with genes and TSS
create_annotated_df <- function(gr_genes, gr_TSS) {
  # Check if the GRanges objects are not empty
  if (length(gr_genes) == 0 || length(gr_TSS) == 0) {
    stop("The GRanges objects for genes or TSS are empty!")
  }
  
  # Find the nearest TSS indices based on specific rules
  nearest_indices <- sapply(seq_along(gr_genes), function(i) {
    # Check the strand of the current gene
    gene <- gr_genes[i]
    
    # Ensure strand values are valid
    gene_strand <- as.character(strand(gene)) # Convert to character for comparison
    if (gene_strand == "+") {
      # For positive strand, consider the start of the gene
      nearest_TSS <- which.min(abs(start(gr_TSS) - start(gene)))
    } else if (gene_strand == "-") {
      # For negative strand, consider the end of the gene
      nearest_TSS <- which.min(abs(end(gr_TSS) - end(gene)))
    } else {
      # Handle unexpected strand values (e.g., NA or other)
      nearest_TSS <- NA
    }
    return(nearest_TSS)
  })
  
  # Check if the nearest indices are valid (not NA)
  valid_indices <- !is.na(nearest_indices)
  
  # Assign TSS values to genes, handling invalid indices
  nearest_TSS_start <- ifelse(valid_indices, start(gr_TSS)[nearest_indices], NA)
  nearest_TSS_end <- ifelse(valid_indices, end(gr_TSS)[nearest_indices], NA)

  # Create the annotated dataframe with all genes, including those without TSS matches
  annotated_df <- data.frame(
    chr = as.character(seqnames(gr_genes)),
    start = start(gr_genes),
    end = end(gr_genes),
    gene_name = mcols(gr_genes)$hgnc_symbol,
    strand = as.character(strand(gr_genes)),
    nearest_TSS_start = nearest_TSS_start,
    nearest_TSS_end = nearest_TSS_end
  )
  
  return(annotated_df)
}

