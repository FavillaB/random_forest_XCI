library(ggplot2)
library(tidyr)
library(dplyr)

names(data.Z.score)

#PRC1 features

data_long <- data.Z.score %>%
  pivot_longer(
    cols = c(
      number_of_unmethylated,
      mean0_DNASE.gm12878,
      mean0_EZH2.gm12878,
      distance_XIST_linear,
      ALU_density,
      LINE_density,
      gene_density),
    
    names_to = "Feature",
    values_to = "Z_score"
  ) %>%
  mutate(
    Feature = recode(
      Feature,
      "number_of_unmethylated" = "#unmethylated Cs",
      "mean0_DNASE.gm12878" = "DNAse hypersensitivity",
      "mean0_EZH2.gm12878" = "EZH2",
      "distance_XIST_linear" = "Linear distance to XIST",
      "ALU_density" = "Alu density",
      "LINE_density" = "LINE density",
      "gene_density" = "Gene density"
    ))

#Figure 4f

p <- ggplot(data_long, aes(x = k_medoids_cluster, y = Z_score, fill = k_medoids_cluster)) +
  geom_violin(size = .3, bw = .1, scale = "count") +
  geom_jitter(position = position_jitter(width = 0.2),
              size = 0.2, alpha = 0.15, color = "black") +
  scale_fill_manual(values = c("1" = "red", 
                               "2" = "blue")) +
  labs(x = "Cluster", y = "Z-score") +
  facet_wrap(~ Feature, scales = "free_y", nrow = 2) +
  theme_minimal(base_size = 13) +
  theme(
    strip.text = element_text(size = 11, face = "bold"),
    axis.text.x = element_text(angle = 45, hjust = 1, size = 9),
    legend.position = "right",                           
    plot.margin = margin(10, 10, 10, 10))+
  coord_cartesian(ylim = c(-2, 5))

print(p)

ggsave("Zscore_violinplots_facets_all.png", plot = p, width = 9, height = 4, dpi = 600)

